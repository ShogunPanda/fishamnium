#!/usr/bin/env fish

set -x -g C_RESET (printf "\033[0m")
set -x -g C_BOLD (printf "\033[1m")
set -x -g C_NORMAL (printf "\033[22m")
set -x -g C_ERROR (printf "\033[31m\033[1m")
set -x -g C_SUCCESS (printf "\033[32m\033[1m")
set -x -g C_PRIMARY (printf "\033[35m\033[1m")
set -x -g C_SECONDARY (printf "\033[34m\033[1m")

# Check fish version and other dependencies
set version_tokens $(string split -- "." "$version")

if test $version_tokens[1] -lt 3 -o $version_tokens[1] -lt 3
  printf "%sFishamnium requires Fish %s3.3.0%s or greater, while you are on %s%s%s.%s\n" "$C_ERROR" "$C_RESET" "$C_ERROR" "$C_RESET" "$version" "$C_ERROR" "$C_RESET"
  exit 1
end

if ! which yq >/dev/null 2>/dev/null
  printf "%sFishamnium requires yq %s4.18.1%s or greater. Please check %shttp://mikefarah.github.io/yq/#install%s.%s\n" "$C_ERROR" "$C_RESET" "$C_ERROR" "$C_RESET" "$C_ERROR" "$C_RESET"
  exit 1
end

if ! which starship >/dev/null 2>/dev/null
  printf "%sFishamnium requires starship %s1.2.1%s or greater. Please check %shttps://starship.rs/guide/#🚀-installation%s.%s\n" "$C_ERROR" "$C_RESET" "$C_ERROR" "$C_RESET" "$C_ERROR" "$C_RESET"
  exit 1
end

# Set global parameters
argparse "l/local" "u/ininstall" -- $argv

set origPwd $PWD
set repo ShogunPanda/fishamnium
set target ~/.local/share/fishamnium
set loaderDirectory ~/.config/fish/conf.d
set loader "$loaderDirectory/fishamnium.fish"
set source /tmp/fishamnium-(date +%Y%m%d%H%M%S)

# Check main operation
if ! set -q _flag_u
  # Clone locally if asked to
  if ! set -q _flag_l
    set -l fishamniumVersion $(curl -s https://api.github.com/repos/$repo/releases | yq ".[0].tag_name | sub(\"v\", \"\")")
    printf "%s--> Downloading Fishamnium %s into %s%s%s ...%s\n" "$C_PRIMARY" "$fishamniumVersion" "$C_RESET" "$source" "$C_PRIMARY" "$C_RESET"
    
    command mkdir -p $source; or exit 1
    command curl -sSL -o $source/fishamnium.tar.gz https://github.com/$repo/releases/latest/download/fishamnium.tar.gz
    cd "$source"
    command tar -zxf $source/fishamnium.tar.gz; or exit 1
  else 
    command rm -rf helper/target; or exit 1
  end

  # Remove previous installations
  printf "%s--> Removing any previous fishamnium installations in %s%s%s ...%s\n" "$C_PRIMARY" "$C_RESET" "$target" "$C_PRIMARY" "$C_RESET"
  command rm -rf "$target" "$loader"; or exit 1

  # Create required directories
  printf "%s--> Creating required directories ...%s\n" "$C_PRIMARY" "$C_RESET"
  command mkdir -vp "$target" "$loaderDirectory"; or exit 1

  # Copy files
  printf "%s--> Copying fishamnium in %s%s%s ...%s\n" "$C_PRIMARY" "$C_RESET" "$target" "$C_PRIMARY" "$C_RESET"
  command cp -av completions data helper installer plugins themes version "$target" | sort; or exit 1

  printf "%s--> Copying loader file in %s%s%s ...%s\n" "$C_PRIMARY" "$C_RESET" "$loader" "$C_PRIMARY" "$C_RESET"
  command cp -av loader.fish "$loader"; or exit 1

  # Build helper
  printf "%s--> Building optimized fishamnium helper ...%s\n" "$C_PRIMARY" "$C_RESET"

  set cargo $(which cargo 2>/dev/null)
  if ! test -x "$cargo"
    printf "%sFishamnium requires cargo to build the helper.%s\n" "$C_ERROR" "$C_RESET"
    exit 1
  end

  cd $target/helper; or exit 1
  command mkdir ../bin; or exit 1
  if test (uname) = Linux
    command env CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_RUSTFLAGS="-C target-feature=+crt-static" $cargo build --release; or exit 1
  else
    command $cargo build --release; or exit 1
  end

  command cp -av target/release/fishamnium "../bin/fishamnium"; or exit 1
  command rm -rf target; or exit 1

  # Ensure permissions
  printf "%s--> Fixing file permissions ...%s\n" "$C_PRIMARY" "$C_RESET"
  command chmod -R a+x "$target" "$loader"; or exit 1

  # Remove temporary directory if needed
  if ! set -q _flag_l
    printf "%s--> Removing temporary installation files in %s%s%s ...%s\n" "$C_PRIMARY" "$C_RESET" "$source" "$C_PRIMARY" "$C_RESET"
    cd "$origPwd"
    command rm -rf "$source"; or exit 1
  end

  # Print a status
  printf "\n%s--> To load fish right now without restarting the terminal, run: %ssource ~/.config/fish/conf.d/fishamnium.fish%s" "$C_SUCCESS" "$C_RESET" "$C_SUCCESS"
  printf "\n%s--> Fishamnium has been installed. Hope you will like it. Enjoy! \U0001F37A%s\n" "$C_SUCCESS" "$C_RESET"
else
  printf "%s--> Removing directory %s%s%s and loader file %s%s%s ...%s\n" "$C_PRIMARY" "$C_RESET" "$target" "$C_PRIMARY" "$C_RESET" "$loader" "$C_PRIMARY" "$C_RESET"
  command rm -rf "$target" "$loader"; or exit 1

  printf "%s--> Removing loader file %s%s%s ...%s\n" "$C_PRIMARY" "$C_RESET" "$loader" "$C_PRIMARY" "$C_RESET"
  command rm -rf "$loader"; or exit 1

  printf "\n%s--> Fishamnium has been uninstalled. Hope you liked it. Farewell! \U0001F37A%s\n" "$C_SUCCESS" "$C_RESET"
end
